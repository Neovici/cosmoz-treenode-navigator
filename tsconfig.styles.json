{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "./dist",
		"rootDir": "./",
		"allowJs": true,
		"declaration": false,
		"emitDeclarationOnly": false,
		"skipLibCheck": true
	},
	"include": ["src/**/*.styles.js", "demo/**/*.styles.js"],
	"exclude": ["node_modules", "dist"]
}
